{
  "name": "freakandbun",
  "description": "```sh bunx create-astro@latest -- --template Frikadellios/freakandbun ```",
  "keywords": [
    "bun.sh",
    "frontmatter.codes",
    "astro.build",
    "react.dev",
    "obsidian.md",
    "biomejs.dev",
    "markdown",
    "mdxjs.dev",
    "gitlocalize.com"
  ],
  "author": "Hrihorii Ilin <devopsick@pm.me>",
  "license": "MIT",
  "repository": "https://github.com/Frikadellios/freakandbun",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "bunx --bun astro dev --watch",
    "start": "bun astro check && bunx --bun astro dev --verbose",
    "build": "bunx --bun astro build",
    "preview": "bunx --bun astro preview",
    "postbuild": "pagefind --site dist",
    "format:check": "prettier --plugin-search-dir=. --check .",
    "format": "prettier --plugin-search-dir=. --write .",
    "lint": "eslint .",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.5.5",
    "@astrojs/mdx": "^2.1.1",
    "@astrojs/partytown": "^2.0.4",
    "@astrojs/react": "^3.0.10",
    "@astrojs/rss": "^4.0.5",
    "@astrojs/sitemap": "^3.1.0",
    "@astrojs/tailwind": "^5.1.0",
    "@astrojs/ts-plugin": "^1.4.0",
    "@fontsource-variable/inter": "^5.0.16",
    "@fontsource/londrina-shadow": "^5.0.18",
    "@pagefind/default-ui": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@rollup/plugin-yaml": "^4.1.2",
    "@tailwindcss/typography": "0.5.10",
    "@types/react": "^18.2.57",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/parser": "^6.7.4",
    "astro": "^4.4.1",
    "astro-tina": "^0.1.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "eslint": "^8.53.0",
    "eslint-plugin-astro": "0.31.4",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "lint-staged": "15.2.2",
    "lucide-react": "^0.323.0",
    "mdast-util-to-string": "^4.0.0",
    "million": "latest",
    "motion": "^10.16.4",
    "pagefind": "^1.0.3",
    "prettier": "^3.2.5",
    "prettier-config-standard": "^7.0.0",
    "prettier-plugin-astro": "0.13.0",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reading-time": "^1.5.0",
    "sharp": "^0.33.2",
    "slugify": "^1.6.6",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bun": "latest"
  },
  "lint-staged": {
    "*.{astro,js,jsx,ts,tsx,md,mdx,json}": [
      "prettier --write --plugin-search-dir=."
    ]
  }
}
