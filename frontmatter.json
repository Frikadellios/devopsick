{
  "$schema": "https://beta.frontmatter.codes/frontmatter.schema.json",
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "blog",
      "previewPath": "'blog'",
      "pageBundle": false,
      "clearEmpty": true,
      "fields": []
    }
  ],
  "frontMatter.framework.id": "astro",
  "frontMatter.preview.host": "http://localhost:4321",
  "frontMatter.content.pageFolders": [
    {
      "title": "blog",
      "path": "[[workspace]]/src/content/blog",
      "defaultLocale": "en",
      "locales": [
        {
          "title": "English",
          "locale": "en",
          "path": "../en"
        },
        {
          "title": "German",
          "locale": "de",
          "path": "../de"
        },
        {
          "title": "Russian",
          "locale": "ru",
          "path": "../ru"
        },
        {
          "title": "Ukrainian",
          "locale": "uk",
          "path": "../uk"
        }
      ]
    },
    {
      "title": "docs",
      "path": "[[workspace]]/src/content/docs",
      "defaultLocale": "en",
      "locales": [
        {
          "title": "English",
          "locale": "en",
          "path": "../en"
        },
        {
          "title": "German",
          "locale": "de",
          "path": "../de"
        },
        {
          "title": "Russian",
          "locale": "ru",
          "path": "../ru"
        },
        {
          "title": "Ukrainian",
          "locale": "uk",
          "path": "../uk"
        }
      ]
    },
    {
      "title": "partners",
      "path": "[[workspace]]/src/content/partners",
      "defaultLocale": "en",
      "locales": [
        {
          "title": "English",
          "locale": "en",
          "path": "../en"
        },
        {
          "title": "German",
          "locale": "de",
          "path": "../de"
        },
        {
          "title": "Russian",
          "locale": "ru",
          "path": "../ru"
        },
        {
          "title": "Ukrainian",
          "locale": "uk",
          "path": "../uk"
        }
      ]
    },
    {
      "title": "portfolio",
      "path": "[[workspace]]/src/content/portfolio",
      "defaultLocale": "en",
      "locales": [
        {
          "title": "English",
          "locale": "en",
          "path": "../en"
        },
        {
          "title": "German",
          "locale": "de",
          "path": "../de"
        },
        {
          "title": "Russian",
          "locale": "ru",
          "path": "../ru"
        },
        {
          "title": "Ukrainian",
          "locale": "uk",
          "path": "../uk"
        }
      ]
    },
    {
      "title": "projects",
      "path": "[[workspace]]/src/content/projects",
      "defaultLocale": "en",
      "locales": [
        {
          "title": "English",
          "locale": "en",
          "path": "../en"
        },
        {
          "title": "German",
          "locale": "de",
          "path": "../de"
        },
        {
          "title": "Russian",
          "locale": "ru",
          "path": "../ru"
        },
        {
          "title": "Ukrainian",
          "locale": "uk",
          "path": "../uk"
        }
      ]
    },
    {
      "title": "services",
      "path": "[[workspace]]/src/content/services",
      "defaultLocale": "en",
      "locales": [
        {
          "title": "English",
          "locale": "en",
          "path": "../en"
        },
        {
          "title": "German",
          "locale": "de",
          "path": "../de"
        },
        {
          "title": "Russian",
          "locale": "ru",
          "path": "../ru"
        },
        {
          "title": "Ukrainian",
          "locale": "uk",
          "path": "../uk"
        }
      ]
    }
  ],
  "frontMatter.taxonomy.fieldGroups": [
    {
      "id": "GeneralFields",
      "fields": [
        {
          "title": "Title",
          "name": "title",
          "type": "string",
          "single": true
        },
        {
          "title": "Description",
          "name": "description",
          "type": "string"
        },
        {
          "name": "fieldCollection",
          "type": "fieldCollection",
          "fieldGroup": "GeneralFields"
        }
      ]
    },
    {
      "id": "author",
      "labelField": "name",
      "fields": [
        {
          "title": "Author Name",
          "name": "name",
          "type": "string",
          "single": true
        },
        {
          "title": "Social link",
          "name": "social",
          "type": "string",
          "single": false
        }
      ]
    }
  ],
  "frontMatter.data.files": [
    {
      "id": "authors",
      "title": "Authors",
      "file": "[[workspace]]/data/authors.json",
      "schema": {
        "title": "Author",
        "type": "object",
        "required": [
          "name",
          "url"
        ],
        "properties": {
          "slug": {
            "title": "slug",
            "type": "string"
          },
          "name": {
            "title": "name",
            "type": "string"
          },
          "url": {
            "title": "url",
            "type": "string"
          }
        }
      }
    }
  ],
  "frontMatter.content.publicFolder": {
    "path": "src/assets",
    "relative": true
  },
  "frontMatter.git.enabled": true,
  "frontMatter.framework.startCommand": "bunx --bun astro dev --watch"
}