{
  "$schema": "https://beta.frontmatter.codes/frontmatter.schema.json",
  "frontMatter.content.i18n": [
    {
      "title": "English",
      "locale": "en",
      "path": "en"
    },
    {
      "title": "German",
      "locale": "de",
      "path": "de"
    },
    {
      "title": "Russian",
      "locale": "ru",
      "path": "ru"
    },
    {
      "title": "Ukrainian",
      "locale": "uk",
      "path": "uk"
    }
  ],
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "default",
      "pageBundle": false,
      "previewPath": null,
      "fields": [
        {
          "title": "Title",
          "name": "title",
          "type": "string"
        },
        {
          "title": "Description",
          "name": "description",
          "type": "string"
        },
        {
          "title": "Publishing date",
          "name": "date",
          "type": "datetime",
          "default": "{{now}}",
          "isPublishDate": true
        },
        {
          "title": "Content preview",
          "name": "preview",
          "type": "image"
        },
        {
          "title": "Is in draft",
          "name": "draft",
          "type": "draft"
        },
        {
          "title": "Tags",
          "name": "tags",
          "type": "tags"
        },
        {
          "title": "Category",
          "name": "category",
          "type": "categories",
          "single": true
        },
        {
          "title": "pubDate",
          "name": "pubDate",
          "type": "datetime"
        },
        {
          "title": "heroImage",
          "name": "heroImage",
          "type": "image"
        },
        {
          "title": "Authors",
          "name": "authors",
          "type": "block",
          "fieldGroup": [
            "author"
          ]
        }
      ]
    }
  ],
  "frontMatter.framework.id": "astro",
  "frontMatter.preview.host": "http://localhost:4321",
  "frontMatter.content.pageFolders": [
    {
      "title": "blog",
      "path": "[[workspace]]/src/content/blog",
      "filePrefix": "",
      "defaultLocale": "en",
      "locales": [
        {
          "title": "English",
          "locale": "en",
          "path": "en"
        },
        {
          "title": "German",
          "locale": "de",
          "path": "./de"
        },
        {
          "title": "Russian",
          "locale": "ru",
          "path": "./ru"
        },
        {
          "title": "Ukrainian",
          "locale": "uk",
          "path": "./uk"
        }
      ]
    },
    {
      "title": "docs",
      "path": "[[workspace]]/src/content/docs",
      "filePrefix": "",
      "defaultLocale": "en",
      "locales": [
        {
          "title": "English",
          "locale": "en",
          "path": "en"
        },
        {
          "title": "German",
          "locale": "de",
          "path": "./de"
        },
        {
          "title": "Russian",
          "locale": "ru",
          "path": "./ru"
        },
        {
          "title": "Ukrainian",
          "locale": "uk",
          "path": "./uk"
        }
      ]
    },
    {
      "title": "partners",
      "path": "[[workspace]]/src/content/partners",
      "filePrefix": "",
      "defaultLocale": "en",
      "locales": [
        {
          "title": "English",
          "locale": "en",
          "path": "en"
        },
        {
          "title": "German",
          "locale": "de",
          "path": "./de"
        },
        {
          "title": "Russian",
          "locale": "ru",
          "path": "./ru"
        },
        {
          "title": "Ukrainian",
          "locale": "uk",
          "path": "./uk"
        }
      ]
    },
    {
      "title": "portfolio",
      "path": "[[workspace]]/src/content/portfolio",
      "filePrefix": "",
      "defaultLocale": "en",
      "locales": [
        {
          "title": "English",
          "locale": "en",
          "path": "en"
        },
        {
          "title": "German",
          "locale": "de",
          "path": "./de"
        },
        {
          "title": "Russian",
          "locale": "ru",
          "path": "./ru"
        },
        {
          "title": "Ukrainian",
          "locale": "uk",
          "path": "./uk"
        }
      ]
    },
    {
      "title": "projects",
      "path": "[[workspace]]/src/content/projects",
      "filePrefix": "",
      "defaultLocale": "en",
      "locales": [
        {
          "title": "English",
          "locale": "en",
          "path": "en"
        },
        {
          "title": "German",
          "locale": "de",
          "path": "./de"
        },
        {
          "title": "Russian",
          "locale": "ru",
          "path": "./ru"
        },
        {
          "title": "Ukrainian",
          "locale": "uk",
          "path": "./uk"
        }
      ]
    },
    {
      "title": "services",
      "path": "[[workspace]]/src/content/services",
      "filePrefix": "",
      "defaultLocale": "en",
      "locales": [
        {
          "title": "English",
          "locale": "en",
          "path": "en"
        },
        {
          "title": "German",
          "locale": "de",
          "path": "./de"
        },
        {
          "title": "Russian",
          "locale": "ru",
          "path": "./ru"
        },
        {
          "title": "Ukrainian",
          "locale": "uk",
          "path": "./uk"
        }
      ]
    }
  ],
  "frontMatter.taxonomy.fieldGroups": [
    {
      "id": "GeneralFields",
      "fields": [
        {
          "title": "Title",
          "name": "title",
          "type": "string",
          "single": true
        },
        {
          "title": "Description",
          "name": "description",
          "type": "string"
        },
        {
          "name": "fieldCollection",
          "type": "fieldCollection",
          "fieldGroup": "GeneralFields"
        }
      ]
    },
    {
      "id": "author",
      "labelField": "name",
      "fields": [
        {
          "title": "Author Name",
          "name": "name",
          "type": "string",
          "single": true
        },
        {
          "title": "Social link",
          "name": "social",
          "type": "string",
          "single": false
        }
      ]
    }
  ],
  "frontMatter.data.files": [
    {
      "id": "authors",
      "title": "Authors",
      "file": "[[workspace]]/data/authors.json", // Adapt to your needs
      "schema": {
        "title": "Author",
        "type": "object",
        "required": ["name", "url"],
        "properties": {
          "slug": {
            "title": "slug",
            "type": "string"
          },
          "name": {
            "title": "name",
            "type": "string"
          },
          "url": {
            "title": "url",
            "type": "string"
          }
        }
      }
    }
  ],
  "frontMatter.content.publicFolder": {
    "path": "src/assets",
    "relative": true
  },
  "frontMatter.git.enabled": true,
  "frontMatter.framework.startCommand": "bunx --bun astro dev --watch"
}